# Copy this file to ".env" and fill in your own values.
#
# Session cookies copied from your logged-in browser
# (DevTools > Application > Cookies > https://store.computerzone.pk).
# These expire when your login session ends -- refresh them when the
# scraper starts redirecting to the login page again.
PHPSESSID=your_phpsessid_value_here
CZ_LOGIN=your_cz_login_value_here
